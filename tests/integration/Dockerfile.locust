# Dockerfile for Locust load testing service
# Copies the locustfile into the container to avoid volume mount issues in DinD environments

FROM locustio/locust:2.24.0

# Copy all locustfiles and dependencies into the container (mock and real benchmarks)
COPY locustfile.py /mnt/locust/locustfile.py
COPY locustfile_real.py /mnt/locust/locustfile_real.py
COPY prompt_loader.py /mnt/locust/prompt_loader.py

# Set working directory
WORKDIR /mnt/locust
