{
    "name": "Ranvier Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "BASE_IMAGE": "ghcr.io/ranvier-systems/ranvier-base:latest"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake"
            ]
        }
    },
    "remoteUser": "root",
    "runArgs": [
        "--privileged",
        "--ulimit", "memlock=-1:-1",
        "--cap-add", "SYS_NICE",
        "--cap-add", "SYS_ADMIN"
    ],
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ]
}
