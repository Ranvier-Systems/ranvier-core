BASH_COMPLETION = r'''# rvctl bash completion
# Add to ~/.bashrc: eval "$(rvctl completion bash)"
# Or save to /etc/bash_completion.d/rvctl

_rvctl_completions() {
    local cur prev words cword
    _init_completion || return

    local commands="inspect cluster drain backend route keys health top wait profile export import completion"
    local global_opts="--url -u --admin-key -k --timeout -t --output -o --watch -w --interval --quiet -q --metrics-url --metrics-port --verbose -v --dry-run --help -h"

    # Determine command position (skip global options)
    local cmd=""
    local cmd_index=0
    for ((i=1; i < cword; i++)); do
        case "${words[i]}" in
            --url|-u|--admin-key|-k|--timeout|-t|--output|-o|--interval|--metrics-url|--metrics-port)
                ((i++))  # skip option value
                ;;
            --watch|-w|--quiet|-q|--verbose|-v|--dry-run|--help|-h)
                ;;  # flag only
            -*)
                ;;  # unknown option
            *)
                if [[ -z "$cmd" ]]; then
                    cmd="${words[i]}"
                    cmd_index=$i
                fi
                ;;
        esac
    done

    case "$cmd" in
        inspect)
            if [[ $cword -eq $((cmd_index + 1)) ]]; then
                COMPREPLY=($(compgen -W "routes backends metrics" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "routes" ]]; then
                COMPREPLY=($(compgen -W "--prefix -p --shard -s" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "metrics" ]]; then
                COMPREPLY=($(compgen -W "--raw -r --filter -f" -- "$cur"))
            fi
            ;;
        cluster)
            if [[ $cword -eq $((cmd_index + 1)) ]]; then
                COMPREPLY=($(compgen -W "status" -- "$cur"))
            fi
            ;;
        backend)
            if [[ $cword -eq $((cmd_index + 1)) ]]; then
                COMPREPLY=($(compgen -W "add update delete" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "add" ]]; then
                COMPREPLY=($(compgen -W "--id --ip --port --weight --priority" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "update" ]]; then
                COMPREPLY=($(compgen -W "--id --weight --priority" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "delete" ]]; then
                COMPREPLY=($(compgen -W "--id" -- "$cur"))
            fi
            ;;
        route)
            if [[ $cword -eq $((cmd_index + 1)) ]]; then
                COMPREPLY=($(compgen -W "add delete" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "add" ]]; then
                COMPREPLY=($(compgen -W "--backend -b --content -c --stdin -i" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "delete" ]]; then
                COMPREPLY=($(compgen -W "--backend -b" -- "$cur"))
            fi
            ;;
        keys)
            if [[ $cword -eq $((cmd_index + 1)) ]]; then
                COMPREPLY=($(compgen -W "reload" -- "$cur"))
            fi
            ;;
        completion)
            if [[ $cword -eq $((cmd_index + 1)) ]]; then
                COMPREPLY=($(compgen -W "bash zsh fish" -- "$cur"))
            fi
            ;;
        drain|health|top)
            # No subcommands
            ;;
        wait)
            COMPREPLY=($(compgen -W "--healthy --quorum --backend --status --wait-timeout" -- "$cur"))
            ;;
        profile)
            if [[ $cword -eq $((cmd_index + 1)) ]]; then
                COMPREPLY=($(compgen -W "list add use show delete" -- "$cur"))
            elif [[ "${words[cmd_index + 1]}" == "add" ]]; then
                COMPREPLY=($(compgen -W "--url --admin-key --metrics-url --metrics-port --timeout --force" -- "$cur"))
            fi
            ;;
        export)
            COMPREPLY=($(compgen -W "--file -f" -- "$cur"))
            ;;
        import)
            COMPREPLY=($(compgen -W "--file -f --stdin" -- "$cur"))
            ;;
        "")
            # No command yet - suggest commands and global options
            if [[ "$cur" == -* ]]; then
                COMPREPLY=($(compgen -W "$global_opts" -- "$cur"))
            else
                COMPREPLY=($(compgen -W "$commands" -- "$cur"))
            fi
            ;;
    esac

    # Handle option value completions
    case "$prev" in
        --output|-o)
            COMPREPLY=($(compgen -W "text json" -- "$cur"))
            ;;
        --status)
            COMPREPLY=($(compgen -W "healthy draining dead drained gone" -- "$cur"))
            ;;
        --url|-u|--admin-key|-k|--metrics-url)
            # No completion for URLs/keys
            ;;
    esac
}

complete -F _rvctl_completions rvctl
'''

