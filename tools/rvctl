    case "$state" in
        command)
            _describe -t commands 'rvctl commands' commands
            ;;
        args)
            case "$words[1]" in
                inspect)
                    local -a inspect_targets
                    inspect_targets=(
                        'routes:Inspect radix tree routes'
                        'backends:Inspect backend status'
                        'metrics:Inspect Prometheus metrics'
                    )
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe -t targets 'inspect targets' inspect_targets
                    else
                        case "$words[2]" in
                            routes)
                                _arguments \
                                    '(-p --prefix)'{-p,--prefix}'[Filter by prefix]:prefix' \
                                    '(-s --shard)'{-s,--shard}'[Query specific shard]:shard'
                                ;;
                            metrics)
                                _arguments \
                                    '(-r --raw)'{-r,--raw}'[Output raw Prometheus format]' \
                                    '(-f --filter)'{-f,--filter}'[Filter metrics by pattern]:pattern'
                                ;;
                        esac
                    fi
                    ;;
                cluster)
                    local -a cluster_actions
                    cluster_actions=('status:Show cluster status')
                    _describe -t actions 'cluster actions' cluster_actions
                    ;;
                backend)
                    local -a backend_actions
                    backend_actions=(
                        'add:Register a new backend'
                        'update:Update backend settings'
                        'delete:Remove a backend'
                    )
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe -t actions 'backend actions' backend_actions
                    else
                        case "$words[2]" in
                            add)
                                _arguments \
                                    '--id[Backend ID]:id' \
                                    '--ip[Backend IP/hostname]:ip' \
                                    '--port[Backend port]:port' \
                                    '--weight[Load balancing weight]:weight' \
                                    '--priority[Routing priority]:priority'
                                ;;
                            update)
                                _arguments \
                                    '--id[Backend ID]:id' \
                                    '--weight[New load balancing weight]:weight' \
                                    '--priority[New routing priority]:priority'
                                ;;
                            delete)
                                _arguments '--id[Backend ID]:id'
                                ;;
                        esac
                    fi
                    ;;
                route)
                    local -a route_actions
                    route_actions=(
                        'add:Add a route for a backend'
                        'delete:Delete routes for a backend'
                    )
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe -t actions 'route actions' route_actions
                    else
                        case "$words[2]" in
                            add)
                                _arguments \
                                    '(-b --backend)'{-b,--backend}'[Backend ID]:id' \
                                    '(-c --content)'{-c,--content}'[Content/prompt]:content' \
                                    '(-i --stdin)'{-i,--stdin}'[Read content from stdin]'
                                ;;
                            delete)
                                _arguments '(-b --backend)'{-b,--backend}'[Backend ID]:id'
                                ;;
                        esac
                    fi
                    ;;
                keys)
                    local -a keys_actions
                    keys_actions=('reload:Hot-reload API keys from disk')
                    _describe -t actions 'keys actions' keys_actions
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh fish)'
                    ;;
                drain)
                    _arguments '1:backend_id'
                    ;;
                wait)
                    _arguments \
                        '--healthy[Wait for server to be healthy]' \
                        '--quorum[Wait for quorum to be established]' \
                        '--backend[Backend ID to wait for]:id' \
                        '--status[Target backend status]:status:(healthy draining dead drained gone)' \
                        '--wait-timeout[Maximum wait time in seconds]:seconds'
                    ;;
                profile)
                    local -a profile_actions
                    profile_actions=(
                        'list:List all profiles'
                        'add:Add a new profile'
                        'use:Switch to a profile'
                        'show:Show profile details'
                        'delete:Delete a profile'
                    )
                    if [[ $CURRENT -eq 2 ]]; then
                        _describe -t actions 'profile actions' profile_actions
                    else
                        case "$words[2]" in
                            add)
                                _arguments \
                                    '1:profile name' \
                                    '--url[Ranvier Admin API URL]:url' \
                                    '--admin-key[Admin API key]:key' \
                                    '--metrics-url[Metrics endpoint URL]:url' \
                                    '--metrics-port[Metrics port]:port' \
                                    '--timeout[Default timeout]:seconds' \
                                    '(-f --force)'{-f,--force}'[Overwrite existing profile]'
                                ;;
                            use|show|delete)
                                _arguments '1:profile name'
                                ;;
                        esac
                    fi
                    ;;
                export)
                    _arguments '(-f --file)'{-f,--file}'[Output file]:file:_files'
                    ;;
                import)
                    _arguments \
                        '(-f --file)'{-f,--file}'[Input file]:file:_files' \
                        '--stdin[Read from stdin]'
                    ;;
            esac
            ;;
    esac
}

