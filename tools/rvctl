            # === CACHE ===
            print(f"{Colors.BOLD}Cache{Colors.RESET}")
            print("─" * 60)
            if metrics:
                cache_ratio = get_metric_value(metrics, 'ranvier_cache_hit_ratio')
                tree_hits = get_metric_value(metrics, 'ranvier_radix_tree_lookup_hits_total')
                tree_misses = get_metric_value(metrics, 'ranvier_radix_tree_lookup_misses_total')
                avg_skip = get_metric_value(metrics, 'ranvier_radix_tree_average_prefix_skip_length')

                parts = []
                if cache_ratio is not None:
                    pct = cache_ratio * 100
                    color = Colors.GREEN if pct >= 80 else (Colors.YELLOW if pct >= 50 else Colors.RED)
                    parts.append(f"Hit Ratio: {color}{pct:.1f}%{Colors.RESET}")

                if tree_hits is not None and tree_misses is not None:
                    tree_total = tree_hits + tree_misses
                    if tree_total > 0:
                        tree_hit_pct = tree_hits / tree_total * 100
                        parts.append(f"Tree Hits: {format_number(tree_hits)} ({tree_hit_pct:.0f}%)")

                if avg_skip is not None:
                    parts.append(f"Avg Skip: {avg_skip:.1f} tokens")

                if parts:
                    print(f"  {' │ '.join(parts)}")
                else:
                    print(f"  {Colors.GRAY}(no cache metrics){Colors.RESET}")
            else:
                print(f"  {Colors.GRAY}(metrics unavailable){Colors.RESET}")

            print()

            # === PER-BACKEND LATENCY (if available) ===
            if metrics:
                backend_latencies = metrics['metrics'].get('ranvier_backend_latency_seconds_sum', [])
                backend_counts = {labels.get('backend_id'): value
                                  for labels, value in metrics['metrics'].get('ranvier_backend_latency_seconds_count', [])}

                if backend_latencies:
                    print(f"{Colors.BOLD}Backend Latency{Colors.RESET}")
