            cmd_func = cmd_cluster_status
            supports_watch = True
        else:
            print(f"Unknown cluster action: {args.cluster_action}", file=sys.stderr)
            sys.exit(1)

    # Handle drain command (mutation - no watch)
    elif args.command == 'drain':
        cmd_func = cmd_drain
        supports_watch = False

    # Handle backend command
    elif args.command == 'backend':
        if not args.backend_action:
            backend_parser.print_help()
            sys.exit(1)

        if args.backend_action == 'add':
            cmd_func = cmd_backend_add
            supports_watch = False  # mutation
        elif args.backend_action == 'delete':
            cmd_func = cmd_backend_delete
            supports_watch = False  # mutation
        else:
            print(f"Unknown backend action: {args.backend_action}", file=sys.stderr)
            sys.exit(1)

    # Handle route command
    elif args.command == 'route':
        if not args.route_action:
            route_parser.print_help()
            sys.exit(1)

        if args.route_action == 'add':
            cmd_func = cmd_route_add
            supports_watch = False  # mutation
        elif args.route_action == 'delete':
            cmd_func = cmd_route_delete
            supports_watch = False  # mutation
        else:
            print(f"Unknown route action: {args.route_action}", file=sys.stderr)
            sys.exit(1)

    # Handle keys command
    elif args.command == 'keys':
        if not args.keys_action:
            keys_parser.print_help()
            sys.exit(1)

        if args.keys_action == 'reload':
            cmd_func = cmd_keys_reload
            supports_watch = False  # mutation
        else:
            print(f"Unknown keys action: {args.keys_action}", file=sys.stderr)
            sys.exit(1)

    # Handle health command
    elif args.command == 'health':
        cmd_func = cmd_health
        supports_watch = True

    # Handle completion command (special case - just print and exit)
    elif args.command == 'completion':
        print_completion_script(args.shell)
        sys.exit(0)

    else:
        print(f"Unknown command: {args.command}", file=sys.stderr)
        sys.exit(1)

    # Check watch mode compatibility
    if args.watch and not supports_watch:
        print(f"{Colors.RED}Error:{Colors.RESET} --watch is not supported for mutation commands", file=sys.stderr)
        sys.exit(1)

    # Execute command (with optional watch loop)
    if args.watch:
        run_watch_loop(cmd_func, args)
    else:
        cmd_func(args)


def run_watch_loop(cmd_func, args):
    """Run a command repeatedly in watch mode."""
    interval = args.interval
    iteration = 0

    try:
        while True:
            iteration += 1

            # Clear screen (ANSI escape code)
            print('\033[2J\033[H', end='')

            # Print header with timestamp
            timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            cmd_desc = f"{args.command}"
            if hasattr(args, 'inspect_target') and args.inspect_target:
                cmd_desc += f" {args.inspect_target}"
            elif hasattr(args, 'cluster_action') and args.cluster_action:
                cmd_desc += f" {args.cluster_action}"

            print(f"{Colors.GRAY}Every {interval}s: rvctl {cmd_desc} | {timestamp}{Colors.RESET}")
            print()

            try:
                cmd_func(args)
            except SystemExit:
                # Command called sys.exit() on error - continue watching
                pass

            # Wait for next iteration
            time.sleep(interval)

    except KeyboardInterrupt:
        # Clean exit on Ctrl+C
        print(f"\n{Colors.GRAY}Watch stopped.{Colors.RESET}")
        sys.exit(0)


if __name__ == '__main__':
    main()
