def cmd_backend_update(args):
    """Handle 'backend update' command."""
    base_url = args.url.rstrip('/')

    # Check that at least one update field is specified
    if args.weight is None and args.priority is None:
        print(f"{Colors.RED}Error:{Colors.RESET} Must specify --weight and/or --priority to update",
              file=sys.stderr)
        sys.exit(1)

    # First, get current backend info
    backends_url = f"{base_url}/admin/dump/backends"
    backends_data = make_request_safe(backends_url, admin_key=args.admin_key, timeout=args.timeout)

    if backends_data is None:
        print(f"{Colors.RED}Error:{Colors.RESET} Failed to fetch backends", file=sys.stderr)
        sys.exit(1)

    # Find the target backend
    backends = backends_data.get('backends', [])
    target_backend = None
    for b in backends:
        if b.get('id') == args.id:
            target_backend = b
            break

    if target_backend is None:
        print(f"{Colors.RED}Error:{Colors.RESET} Backend {args.id} not found", file=sys.stderr)
        sys.exit(1)

    # Build update parameters (use current values as defaults)
    current_weight = target_backend.get('weight', 100)
    current_priority = target_backend.get('priority', 0)
    address = target_backend.get('address')
    port = target_backend.get('port')

    new_weight = args.weight if args.weight is not None else current_weight
    new_priority = args.priority if args.priority is not None else current_priority

    # Dry-run mode
    if args.dry_run:
        print(f"{Colors.CYAN}[dry-run]{Colors.RESET} Would update backend {args.id}")
        print(f"  Address:  {address}:{port}")
        if args.weight is not None:
            print(f"  Weight:   {current_weight} -> {new_weight}")
        if args.priority is not None:
            print(f"  Priority: {current_priority} -> {new_priority}")
        return

    # Delete and re-add with new values (Ranvier API doesn't have a direct update)
    # First delete
    delete_url = f"{base_url}/admin/backends?id={args.id}"
    delete_result = make_request_safe(delete_url, method='DELETE',
                                       admin_key=args.admin_key, timeout=args.timeout)

    if delete_result is None or delete_result.get('status') != 'ok':
        print(f"{Colors.RED}Error:{Colors.RESET} Failed to update backend (delete step failed)",
              file=sys.stderr)
        sys.exit(1)

    # Then re-add with new values
    params = [
        f"id={args.id}",
        f"ip={address}",
        f"port={port}",
        f"weight={new_weight}",
        f"priority={new_priority}"
    ]
    add_url = f"{base_url}/admin/backends?{'&'.join(params)}"
    add_result = make_request_safe(add_url, method='POST',
                                    admin_key=args.admin_key, timeout=args.timeout)

    if add_result is None or add_result.get('status') != 'ok':
        print(f"{Colors.RED}Error:{Colors.RESET} Failed to update backend (add step failed)",
              file=sys.stderr)
        print(f"{Colors.YELLOW}Warning:{Colors.RESET} Backend may be in an inconsistent state!",
              file=sys.stderr)
        sys.exit(1)

    # JSON output mode
    if args.output == 'json':
        output = {
            'status': 'ok',
            'id': args.id,
            'address': address,
            'port': port,
            'weight': new_weight,
            'priority': new_priority,
            'previous_weight': current_weight,
            'previous_priority': current_priority
        }
        print(json.dumps(output, indent=2))
        return

    # Text output
    print(f"{Colors.GREEN}Success:{Colors.RESET} Backend {args.id} updated")
    print(f"  Address:  {address}:{port}")

    if args.weight is not None:
        print(f"  Weight:   {current_weight} -> {new_weight}")
    else:
        print(f"  Weight:   {new_weight}")

    if args.priority is not None:
        print(f"  Priority: {current_priority} -> {new_priority}")
    else:
        print(f"  Priority: {new_priority}")


def cmd_inspect_metrics(args):
    """Handle 'inspect metrics' command."""
    # Determine metrics URL
    # Priority: --metrics-url > RANVIER_METRICS_URL > derive from --url with --metrics-port
    if args.metrics_url:
        metrics_url = args.metrics_url.rstrip('/')
    elif os.environ.get('RANVIER_METRICS_URL'):
        metrics_url = os.environ.get('RANVIER_METRICS_URL').rstrip('/')
    else:
        # Derive from --url, replacing the port
        parsed = urllib.parse.urlparse(args.url)
        metrics_port = args.metrics_port or 9180
        metrics_url = f"{parsed.scheme}://{parsed.hostname}:{metrics_port}"

    url = f"{metrics_url}/metrics"

    if args.verbose:
        print(f"{Colors.BOLD}Fetching metrics from {url}...{Colors.RESET}")
        print()

    raw_text = fetch_metrics_text(url, timeout=args.timeout)

    # If --raw flag, just print the raw output (with optional filter)
    if args.raw:
        if args.filter:
            pattern = re.compile(args.filter, re.IGNORECASE)
            lines = []
            current_metric = None
            for line in raw_text.split('\n'):
                if line.startswith('# HELP ') or line.startswith('# TYPE '):
                    metric_name = line.split()[2] if len(line.split()) > 2 else ''
                    current_metric = metric_name
                    if pattern.search(metric_name):
                        lines.append(line)
                elif line.startswith('#'):
                    continue
                elif line.strip():
                    metric_name = line.split('{')[0].split()[0] if line else ''
                    if pattern.search(metric_name):
                        lines.append(line)
            print('\n'.join(lines))
        else:
            print(raw_text)
        return

    # Parse and display formatted metrics
    parsed = parse_prometheus_metrics(raw_text)

    # JSON output mode
    if args.output == 'json':
        # Convert parsed metrics to JSON-friendly format
        output = {
            'metrics': {},
            'help': parsed.get('help', {}),
            'type': parsed.get('type', {})
        }
        for name, values in parsed['metrics'].items():
            if args.filter and not re.search(args.filter, name, re.IGNORECASE):
                continue
            output['metrics'][name] = [
                {'labels': labels, 'value': value}
                for labels, value in values
            ]
        print(json.dumps(output, indent=2))
        return

    metrics = parsed['metrics']

    # If filter specified, show filtered metrics
    if args.filter:
        pattern = re.compile(args.filter, re.IGNORECASE)
        filtered = {k: v for k, v in metrics.items() if pattern.search(k)}

        print(f"{Colors.BOLD}Filtered Metrics{Colors.RESET} (pattern: {args.filter})")
        print("=" * 70)

        if not filtered:
            print(f"{Colors.GRAY}(no metrics match filter){Colors.RESET}")
            return

        for name in sorted(filtered.keys()):
            values = filtered[name]
            mtype = parsed['type'].get(name, 'unknown')
            print(f"\n{Colors.CYAN}{name}{Colors.RESET} ({mtype})")
            for labels, value in values:
                if labels:
                    label_str = ', '.join(f'{k}="{v}"' for k, v in labels.items())
                    print(f"  {{{label_str}}}: {format_number(value)}")
                else:
                    print(f"  {format_number(value)}")
        return

    # Display formatted summary
    print(f"{Colors.BOLD}Ranvier Metrics Summary{Colors.RESET}")
    print("=" * 70)

    # Request Counters
    print(f"\n{Colors.BOLD}Request Counters{Colors.RESET}")
    print("─" * 40)

    total = get_metric_value(parsed, 'ranvier_http_requests_total') or 0
    success = get_metric_value(parsed, 'ranvier_http_requests_success') or 0
    failed = get_metric_value(parsed, 'ranvier_http_requests_failed') or 0
    timeout = get_metric_value(parsed, 'ranvier_http_requests_timeout') or 0
    rate_limited = get_metric_value(parsed, 'ranvier_http_requests_rate_limited') or 0
    backpressure = get_metric_value(parsed, 'ranvier_http_requests_backpressure_rejected') or 0

    print(f"  Total Requests:     {format_number(total)}")
    print(f"  {Colors.GREEN}Successful:{Colors.RESET}         {format_number(success)}")
    print(f"  {Colors.RED}Failed:{Colors.RESET}             {format_number(failed)}")
    print(f"  {Colors.YELLOW}Timeout:{Colors.RESET}            {format_number(timeout)}")
    print(f"  {Colors.YELLOW}Rate Limited:{Colors.RESET}       {format_number(rate_limited)}")
    print(f"  {Colors.YELLOW}Backpressure:{Colors.RESET}       {format_number(backpressure)}")

    if total > 0:
        success_rate = (success / total) * 100
        color = Colors.GREEN if success_rate >= 99 else (Colors.YELLOW if success_rate >= 95 else Colors.RED)
        print(f"  {Colors.BOLD}Success Rate:{Colors.RESET}       {color}{success_rate:.2f}%{Colors.RESET}")

    # Active Requests
    active = get_metric_value(parsed, 'ranvier_active_proxy_requests')
    if active is not None:
        print(f"  Active Requests:    {format_number(active)}")

    # Cache Performance
    print(f"\n{Colors.BOLD}Cache Performance{Colors.RESET}")
    print("─" * 40)

    cache_ratio = get_metric_value(parsed, 'ranvier_cache_hit_ratio')
    if cache_ratio is not None:
        pct = cache_ratio * 100
        color = Colors.GREEN if pct >= 80 else (Colors.YELLOW if pct >= 50 else Colors.RED)
        print(f"  Cache Hit Ratio:    {color}{pct:.1f}%{Colors.RESET}")

    avg_skip = get_metric_value(parsed, 'ranvier_radix_tree_average_prefix_skip_length')
    if avg_skip is not None:
        print(f"  Avg Prefix Skip:    {avg_skip:.1f} tokens")

    # Radix Tree Stats
    tree_hits = get_metric_value(parsed, 'ranvier_radix_tree_lookup_hits_total')
    tree_misses = get_metric_value(parsed, 'ranvier_radix_tree_lookup_misses_total')
    if tree_hits is not None and tree_misses is not None:
        tree_total = tree_hits + tree_misses
        if tree_total > 0:
            hit_rate = (tree_hits / tree_total) * 100
            print(f"  Tree Lookup Hits:   {format_number(tree_hits)} ({hit_rate:.1f}%)")
            print(f"  Tree Lookup Misses: {format_number(tree_misses)}")

    # Slab utilization
    slab_util = get_metric_value(parsed, 'ranvier_radix_tree_slab_utilization_ratio')
    if slab_util is not None:
        print(f"  Slab Utilization:   {slab_util*100:.1f}%")

    # Circuit Breaker
    print(f"\n{Colors.BOLD}Circuit Breaker{Colors.RESET}")
    print("─" * 40)

    cb_opens = get_metric_value(parsed, 'ranvier_circuit_breaker_opens') or 0
    fallbacks = get_metric_value(parsed, 'ranvier_fallback_attempts') or 0

    if cb_opens > 0:
        print(f"  {Colors.RED}Circuit Opens:{Colors.RESET}      {format_number(cb_opens)}")
    else:
        print(f"  Circuit Opens:      {format_number(cb_opens)}")
    print(f"  Fallback Attempts:  {format_number(fallbacks)}")

    # Tokenizer Stats
    print(f"\n{Colors.BOLD}Tokenizer{Colors.RESET}")
    print("─" * 40)

    tok_errors = get_metric_value(parsed, 'ranvier_tokenizer_errors') or 0
    tok_skipped = get_metric_value(parsed, 'ranvier_tokenization_skipped') or 0
    prefix_used = get_metric_value(parsed, 'ranvier_prefix_boundary_used') or 0
    prefix_client = get_metric_value(parsed, 'ranvier_prefix_boundary_client') or 0

    if tok_errors > 0:
        print(f"  {Colors.RED}Tokenizer Errors:{Colors.RESET}   {format_number(tok_errors)}")
    else:
        print(f"  Tokenizer Errors:   {format_number(tok_errors)}")
    print(f"  Tokenization Skip:  {format_number(tok_skipped)}")
    print(f"  Prefix Boundary:    {format_number(prefix_used)} (client: {format_number(prefix_client)})")

    # Cross-shard dispatch
    cross_shard = get_metric_value(parsed, 'ranvier_tokenizer_cross_shard_dispatches')
    if cross_shard is not None:
        print(f"  Cross-Shard Dispatch: {format_number(cross_shard)}")

    # Per-Backend Latencies (if any)
    backend_latencies = [(labels, value) for labels, value in metrics.get('ranvier_backend_latency_seconds_sum', [])
                         if 'backend_id' in labels]
    backend_counts = {labels.get('backend_id'): value
                      for labels, value in metrics.get('ranvier_backend_latency_seconds_count', [])}

    if backend_latencies:
        print(f"\n{Colors.BOLD}Per-Backend Latency (avg){Colors.RESET}")
        print("─" * 40)
        for labels, sum_val in sorted(backend_latencies, key=lambda x: x[0].get('backend_id', '')):
            backend_id = labels.get('backend_id', '?')
            count = backend_counts.get(backend_id, 1)
            avg_ms = (sum_val / count) * 1000 if count > 0 else 0
            color = Colors.GREEN if avg_ms < 100 else (Colors.YELLOW if avg_ms < 500 else Colors.RED)
            print(f"  Backend {backend_id:>3}: {color}{avg_ms:.1f}ms{Colors.RESET} (n={format_number(count)})")

    # Cluster Stats (if available)
    peers_alive = get_metric_value(parsed, 'ranvier_cluster_peers_alive')
    if peers_alive is not None:
        print(f"\n{Colors.BOLD}Cluster{Colors.RESET}")
        print("─" * 40)
        print(f"  Peers Alive:        {format_number(peers_alive)}")

        gossip_sent = get_metric_value(parsed, 'ranvier_cluster_gossip_messages_sent')
        gossip_recv = get_metric_value(parsed, 'ranvier_cluster_gossip_messages_received')
        if gossip_sent is not None:
            print(f"  Gossip Sent:        {format_number(gossip_sent)}")
        if gossip_recv is not None:
            print(f"  Gossip Received:    {format_number(gossip_recv)}")

    print()
    print(f"{Colors.GRAY}Use --raw for full Prometheus output, --filter <pattern> to search{Colors.RESET}")


