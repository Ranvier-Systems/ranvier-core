                        print(f"  {Colors.GRAY}... and {len(latency_items) - 8} more{Colors.RESET}")
                    print()

            # Wait for next refresh
            time.sleep(interval)

    except KeyboardInterrupt:
        print(f"\n{Colors.GRAY}Dashboard stopped.{Colors.RESET}")
        sys.exit(0)


def cmd_wait(args):
    """Handle 'wait' command - wait for a condition to be met."""
    base_url = args.url.rstrip('/')
    wait_timeout = args.wait_timeout
    poll_interval = 1.0  # Check every second

    # Validate arguments
    has_condition = args.healthy or args.quorum or args.backend is not None
    if not has_condition:
        print(f"{Colors.RED}Error:{Colors.RESET} Must specify at least one condition: --healthy, --quorum, or --backend with --status",
              file=sys.stderr)
        sys.exit(1)

    if args.backend is not None and not args.status:
        print(f"{Colors.RED}Error:{Colors.RESET} --backend requires --status", file=sys.stderr)
        sys.exit(1)

    if args.status and args.backend is None:
        print(f"{Colors.RED}Error:{Colors.RESET} --status requires --backend", file=sys.stderr)
        sys.exit(1)

    # Build condition description
    conditions = []
    if args.healthy:
        conditions.append("server healthy")
    if args.quorum:
        conditions.append("quorum established")
    if args.backend is not None:
        conditions.append(f"backend {args.backend} {args.status}")

    condition_desc = " and ".join(conditions)

    if not args.quiet:
        timeout_str = f" (timeout: {wait_timeout}s)" if wait_timeout else ""
        print(f"{Colors.BOLD}Waiting for:{Colors.RESET} {condition_desc}{timeout_str}")

    start_time = time.time()

    try:
        while True:
            elapsed = time.time() - start_time

            # Check timeout
            if wait_timeout and elapsed >= wait_timeout:
                if not args.quiet:
                    print(f"\n{Colors.RED}Timeout:{Colors.RESET} Condition not met after {wait_timeout}s")
                sys.exit(1)

            all_conditions_met = True
            status_parts = []

            # Check --healthy condition
            if args.healthy:
                health_data = make_request_safe(f"{base_url}/health", timeout=args.timeout)
                if health_data:
                    status = health_data.get('status', 'unknown')
                    is_healthy = status in ('healthy', 'ok')
                    if is_healthy:
                        status_parts.append(f"{Colors.GREEN}healthy{Colors.RESET}")
                    else:
                        status_parts.append(f"{Colors.YELLOW}{status}{Colors.RESET}")
                        all_conditions_met = False
                else:
                    status_parts.append(f"{Colors.RED}unreachable{Colors.RESET}")
                    all_conditions_met = False

            # Check --quorum condition
            if args.quorum:
                health_data = make_request_safe(f"{base_url}/health", timeout=args.timeout)
                if health_data:
                    quorum_healthy = health_data.get('quorum_healthy')
                    if quorum_healthy is True:
                        status_parts.append(f"quorum:{Colors.GREEN}ok{Colors.RESET}")
                    elif quorum_healthy is False:
                        status_parts.append(f"quorum:{Colors.YELLOW}degraded{Colors.RESET}")
                        all_conditions_met = False
                    else:
                        # quorum_healthy not in response - maybe not clustered
                        status_parts.append(f"quorum:{Colors.GRAY}n/a{Colors.RESET}")
                        # Consider this met if clustering isn't enabled
                else:
                    status_parts.append(f"quorum:{Colors.RED}unreachable{Colors.RESET}")
                    all_conditions_met = False

            # Check --backend --status condition
            if args.backend is not None:
                backends_data = make_request_safe(f"{base_url}/admin/dump/backends",
                                                   admin_key=args.admin_key, timeout=args.timeout)
                backend_found = False
                backend_status = "unknown"

                if backends_data:
                    backends = backends_data.get('backends', [])
                    for b in backends:
                        if b.get('id') == args.backend:
                            backend_found = True
                            is_dead = b.get('is_dead', False)
                            is_draining = b.get('is_draining', False)

                            if is_dead:
                                backend_status = "dead"
                            elif is_draining:
                                backend_status = "draining"
                            else:
                                backend_status = "healthy"
                            break

                # Determine if condition is met
                target_status = args.status.lower()
                condition_met = False

                if target_status == 'healthy':
                    condition_met = backend_found and backend_status == 'healthy'
                elif target_status == 'draining':
                    condition_met = backend_found and backend_status == 'draining'
                elif target_status == 'dead':
                    condition_met = backend_found and backend_status == 'dead'
                elif target_status == 'drained':
                    # "drained" means backend is gone or dead (fully drained)
                    condition_met = not backend_found or backend_status == 'dead'
                elif target_status == 'gone' or target_status == 'removed':
                    condition_met = not backend_found
                else:
                    print(f"{Colors.RED}Error:{Colors.RESET} Unknown status '{args.status}'. "
                          f"Valid: healthy, draining, dead, drained, gone", file=sys.stderr)
                    sys.exit(1)

                if backend_found:
                    color = Colors.GREEN if condition_met else Colors.YELLOW
                    status_parts.append(f"backend {args.backend}:{color}{backend_status}{Colors.RESET}")
                else:
                    if target_status in ('drained', 'gone', 'removed'):
                        status_parts.append(f"backend {args.backend}:{Colors.GREEN}gone{Colors.RESET}")
                    else:
                        status_parts.append(f"backend {args.backend}:{Colors.GRAY}not found{Colors.RESET}")

                if not condition_met:
                    all_conditions_met = False

            # Print progress (overwrite line)
            if not args.quiet:
                elapsed_str = f"{elapsed:.0f}s"
                status_str = " | ".join(status_parts)
                print(f"\r  [{elapsed_str}] {status_str}    ", end='', flush=True)

            # Check if all conditions met
            if all_conditions_met:
                if not args.quiet:
                    print(f"\n{Colors.GREEN}Success:{Colors.RESET} All conditions met after {elapsed:.1f}s")
                sys.exit(0)

            # Wait before next check
            time.sleep(poll_interval)

    except KeyboardInterrupt:
        if not args.quiet:
            print(f"\n{Colors.YELLOW}Cancelled{Colors.RESET}")
        sys.exit(130)  # Standard exit code for Ctrl+C


def cmd_backend_add(args):
