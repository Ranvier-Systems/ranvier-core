#!/usr/bin/env python3
"""
rvctl - Ranvier Control CLI

A command-line tool to inspect and manage a running Ranvier instance.
Communicates with the Ranvier Admin API via JSON/HTTP.

Usage:
    rvctl inspect routes [--prefix TOKEN_IDS] [--shard SHARD_ID]
    rvctl inspect backends
    rvctl inspect metrics [--raw] [--filter PATTERN]
    rvctl cluster status
    rvctl drain <backend_id>
    rvctl backend add --id <id> --ip <ip> --port <port> [--weight <w>] [--priority <p>]
    rvctl backend delete --id <id>
    rvctl route add --backend <id> --content "prompt text"
    rvctl route add --backend <id> --stdin < file.txt
    rvctl route delete --backend <id>
    rvctl keys reload
    rvctl health
    rvctl completion {bash,zsh,fish}

Authentication:
    Set RANVIER_ADMIN_KEY environment variable or use --admin-key flag.

Global Options:
    --url, -u          Admin API URL (default: http://localhost:8080)
    --admin-key, -k    Admin API key (or set RANVIER_ADMIN_KEY)
    --timeout, -t      Request timeout in seconds (default: 30)
    --output, -o       Output format: text (default) or json
    --watch, -w        Watch mode: continuously refresh output
    --interval         Watch refresh interval in seconds (default: 2.0)
    --metrics-url      Metrics endpoint URL (or set RANVIER_METRICS_URL)
    --metrics-port     Metrics port override (default: 9180)
    --verbose, -v      Enable verbose output

Examples:
    # Inspect all routes across shards
    rvctl inspect routes

    # Inspect routes with a specific prefix filter
    rvctl inspect routes --prefix "1234,5678,9012"

    # Show backend health status
    rvctl inspect backends

    # Show Prometheus metrics summary
    rvctl inspect metrics

    # Show raw Prometheus metrics
    rvctl inspect metrics --raw

    # Filter metrics by pattern
    rvctl inspect metrics --filter "backend_latency"

    # Use custom metrics URL (for Docker port mapping)
    rvctl --metrics-url http://localhost:19180 inspect metrics

    # Show cluster/quorum status
    rvctl cluster status

    # Drain a specific backend
    rvctl drain 1

    # Register a new backend
    rvctl backend add --id 1 --ip 192.168.1.100 --port 8000

    # Register a backend with weight and priority
    rvctl backend add --id 2 --ip gpu-server.local --port 8000 --weight 200 --priority 1

    # Remove a backend
    rvctl backend delete --id 1

    # Add a route for a backend (content from argument)
    rvctl route add --backend 1 --content "You are a helpful assistant."

    # Add a route for a backend (content from stdin)
    echo "System prompt here" | rvctl route add --backend 1 --stdin

    # Delete all routes for a backend
    rvctl route delete --backend 1

    # Hot-reload API keys from disk
    rvctl keys reload

    # Quick health check (no auth required)
    rvctl health

    # Use shorter timeout for faster failure detection
    rvctl --timeout 5 backend add --id 1 --ip 192.168.1.100 --port 8000

    # Output as JSON for scripting
    rvctl --output json inspect backends | jq '.backends[].id'

    # Watch backend status with 1-second refresh
    rvctl --watch --interval 1 inspect backends

    # Watch health continuously
    rvctl -w health

    # Enable shell completions (bash)
    eval "$(rvctl completion bash)"

    # Enable shell completions (zsh)
    eval "$(rvctl completion zsh)"

    # Enable shell completions (fish)
    rvctl completion fish > ~/.config/fish/completions/rvctl.fish
"""

