def main():
    parser = argparse.ArgumentParser(
        description='Ranvier Control CLI - Inspect and manage Ranvier instances',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__
    )

    # Global options
    parser.add_argument('--url', '-u', default='http://localhost:8080',
                        help='Ranvier Admin API URL (default: http://localhost:8080)')
    parser.add_argument('--admin-key', '-k',
                        default=os.environ.get('RANVIER_ADMIN_KEY'),
                        help='Admin API key (or set RANVIER_ADMIN_KEY env var)')
    parser.add_argument('--metrics-url',
                        help='Metrics endpoint URL (or set RANVIER_METRICS_URL env var)')
    parser.add_argument('--metrics-port', type=int,
                        help='Metrics port (default: 9180, used with --url host)')
    parser.add_argument('--verbose', '-v', action='store_true',
                        help='Enable verbose output')
    parser.add_argument('--timeout', '-t', type=int, default=30,
                        help='Request timeout in seconds (default: 30)')
    parser.add_argument('--output', '-o', choices=['text', 'json'], default='text',
                        help='Output format: text (default) or json')
    parser.add_argument('--watch', '-w', action='store_true',
                        help='Watch mode: continuously refresh output')
    parser.add_argument('--interval', type=float, default=2.0,
                        help='Watch refresh interval in seconds (default: 2.0)')

    subparsers = parser.add_subparsers(dest='command', help='Commands')

    # inspect command
    inspect_parser = subparsers.add_parser('inspect', help='Inspect Ranvier state')
    inspect_subparsers = inspect_parser.add_subparsers(dest='inspect_target', help='What to inspect')

    # inspect routes
    routes_parser = inspect_subparsers.add_parser('routes', help='Inspect radix tree routes')
    routes_parser.add_argument('--prefix', '-p',
                               help='Filter by prefix (comma-separated token IDs)')
    routes_parser.add_argument('--shard', '-s', type=int,
                               help='Query specific shard (not yet implemented)')

    # inspect backends
    backends_parser = inspect_subparsers.add_parser('backends', help='Inspect backend status')

    # inspect metrics
    metrics_parser = inspect_subparsers.add_parser('metrics', help='Inspect Prometheus metrics')
    metrics_parser.add_argument('--raw', '-r', action='store_true',
                                 help='Output raw Prometheus format')
    metrics_parser.add_argument('--filter', '-f',
                                 help='Filter metrics by name pattern (regex)')

    # cluster command
    cluster_parser = subparsers.add_parser('cluster', help='Cluster operations')
    cluster_subparsers = cluster_parser.add_subparsers(dest='cluster_action', help='Cluster action')

    # cluster status
    status_parser = cluster_subparsers.add_parser('status', help='Show cluster status')

    # drain command
    drain_parser = subparsers.add_parser('drain', help='Drain a backend')
    drain_parser.add_argument('backend_id', type=int, help='Backend ID to drain')

    # backend command
    backend_parser = subparsers.add_parser('backend', help='Backend management')
    backend_subparsers = backend_parser.add_subparsers(dest='backend_action', help='Backend action')

    # backend add
    backend_add_parser = backend_subparsers.add_parser('add', help='Register a new backend')
    backend_add_parser.add_argument('--id', type=int, required=True,
                                     help='Unique backend identifier')
    backend_add_parser.add_argument('--ip', required=True,
                                     help='Backend IP address or hostname')
    backend_add_parser.add_argument('--port', type=int, required=True,
                                     help='Backend port')
    backend_add_parser.add_argument('--weight', type=int,
                                     help='Load balancing weight (default: 100)')
    backend_add_parser.add_argument('--priority', type=int,
                                     help='Routing priority (default: 0, lower = preferred)')

    # backend delete
    backend_delete_parser = backend_subparsers.add_parser('delete', help='Remove a backend')
    backend_delete_parser.add_argument('--id', type=int, required=True,
                                        help='Backend ID to delete')

    # route command
    route_parser = subparsers.add_parser('route', help='Route management')
    route_subparsers = route_parser.add_subparsers(dest='route_action', help='Route action')

    # route add
    route_add_parser = route_subparsers.add_parser('add', help='Add a route for a backend')
