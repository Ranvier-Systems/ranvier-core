def get_config_path() -> str:
    """Get the path to the config file, creating directory if needed."""
    config_dir = os.path.expanduser('~/.config/rvctl')
    config_path = os.path.join(config_dir, 'config.json')

    # Also check legacy path
    legacy_path = os.path.expanduser('~/.rvctl.json')
    if os.path.exists(legacy_path) and not os.path.exists(config_path):
        return legacy_path

    return config_path


def load_config() -> Dict[str, Any]:
    """Load configuration from config file.

    Searches for config in order:
    1. ~/.config/rvctl/config.json
    2. ~/.rvctl.json

    Returns empty dict if no config file found.
    """
    config_paths = [
        os.path.expanduser('~/.config/rvctl/config.json'),
        os.path.expanduser('~/.rvctl.json'),
    ]

    for path in config_paths:
        if os.path.exists(path):
            try:
                with open(path, 'r') as f:
                    return json.load(f)
            except (json.JSONDecodeError, IOError) as e:
                print(f"{Colors.YELLOW}Warning:{Colors.RESET} Failed to load config from {path}: {e}",
                      file=sys.stderr)
                return {}

    return {}


def save_config(config: Dict[str, Any]) -> bool:
    """Save configuration to config file."""
    config_path = get_config_path()
    config_dir = os.path.dirname(config_path)

    try:
        # Create config directory if it doesn't exist
        if not os.path.exists(config_dir):
            os.makedirs(config_dir, mode=0o700)

        with open(config_path, 'w') as f:
            json.dump(config, f, indent=2)
        return True
    except IOError as e:
        print(f"{Colors.RED}Error:{Colors.RESET} Failed to save config to {config_path}: {e}",
              file=sys.stderr)
        return False


def get_active_profile(config: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    """Get the currently active profile settings."""
    active_name = config.get('active_profile')
    if not active_name:
        return None

    profiles = config.get('profiles', {})
    return profiles.get(active_name)


def get_effective_config(config: Dict[str, Any]) -> Dict[str, Any]:
    """Get effective configuration, merging active profile with base config."""
    # Start with base config (excluding profiles metadata)
    effective = {k: v for k, v in config.items()
                 if k not in ('profiles', 'active_profile')}

    # Overlay active profile settings
    active_profile = get_active_profile(config)
    if active_profile:
        effective.update(active_profile)

    return effective


def cmd_profile_list(args, config: Dict[str, Any]):
    """Handle 'profile list' command."""
    profiles = config.get('profiles', {})
    active_name = config.get('active_profile')

    if args.output == 'json':
        output = {
            'profiles': list(profiles.keys()),
            'active': active_name
        }
        print(json.dumps(output, indent=2))
        return

    if not profiles:
        print(f"{Colors.GRAY}(no profiles configured){Colors.RESET}")
        print()
        print(f"Create a profile with: rvctl profile add <name> --url <url>")
        return

    print(f"{Colors.BOLD}Profiles{Colors.RESET}")
    print("─" * 50)

    for name, profile in sorted(profiles.items()):
        if name == active_name:
            marker = f"{Colors.GREEN}*{Colors.RESET}"
            name_display = f"{Colors.GREEN}{name}{Colors.RESET}"
        else:
            marker = " "
            name_display = name

        url = profile.get('url', '(no url)')
        print(f"  {marker} {name_display:<15} {url}")

    print()
    if active_name:
        print(f"Active profile: {Colors.GREEN}{active_name}{Colors.RESET}")
    else:
        print(f"No active profile. Use: rvctl profile use <name>")


def cmd_profile_add(args, config: Dict[str, Any]):
    """Handle 'profile add' command."""
    name = args.profile_name

    # Initialize profiles dict if needed
    if 'profiles' not in config:
        config['profiles'] = {}

    # Check if profile already exists
    if name in config['profiles'] and not args.force:
        print(f"{Colors.RED}Error:{Colors.RESET} Profile '{name}' already exists. Use --force to overwrite.",
              file=sys.stderr)
        sys.exit(1)

    # Build profile settings
    profile = {}
    if args.profile_url:
        profile['url'] = args.profile_url
    if args.profile_admin_key:
        profile['admin_key'] = args.profile_admin_key
    if args.profile_metrics_url:
        profile['metrics_url'] = args.profile_metrics_url
    if args.profile_metrics_port:
        profile['metrics_port'] = args.profile_metrics_port
    if args.profile_timeout:
        profile['timeout'] = args.profile_timeout

    if not profile:
        print(f"{Colors.RED}Error:{Colors.RESET} Must specify at least --url for the profile",
              file=sys.stderr)
        sys.exit(1)

    config['profiles'][name] = profile

    if save_config(config):
        action = "Updated" if name in config.get('profiles', {}) else "Created"
        print(f"{Colors.GREEN}Success:{Colors.RESET} {action} profile '{name}'")

        # Offer to activate if no active profile
        if not config.get('active_profile'):
            print(f"  Tip: Use 'rvctl profile use {name}' to activate this profile")
    else:
        sys.exit(1)


def cmd_profile_use(args, config: Dict[str, Any]):
    """Handle 'profile use' command."""
    name = args.profile_name
    profiles = config.get('profiles', {})

    if name not in profiles:
        print(f"{Colors.RED}Error:{Colors.RESET} Profile '{name}' not found", file=sys.stderr)
        if profiles:
            print(f"  Available profiles: {', '.join(sorted(profiles.keys()))}", file=sys.stderr)
        sys.exit(1)

    config['active_profile'] = name

    if save_config(config):
        profile = profiles[name]
        url = profile.get('url', '(no url)')
        print(f"{Colors.GREEN}Switched to profile '{name}'{Colors.RESET}")
        print(f"  URL: {url}")


def cmd_profile_show(args, config: Dict[str, Any]):
    """Handle 'profile show' command."""
    profiles = config.get('profiles', {})
    active_name = config.get('active_profile')

    # Determine which profile to show
    name = args.profile_name if args.profile_name else active_name

    if not name:
        print(f"{Colors.YELLOW}No active profile.{Colors.RESET}")
        print(f"  Use 'rvctl profile use <name>' to activate a profile")
        print(f"  Or specify a profile: rvctl profile show <name>")
        return

    if name not in profiles:
        print(f"{Colors.RED}Error:{Colors.RESET} Profile '{name}' not found", file=sys.stderr)
        sys.exit(1)

    profile = profiles[name]

    if args.output == 'json':
        output = {'name': name, 'active': name == active_name, **profile}
        print(json.dumps(output, indent=2))
        return

    is_active = " (active)" if name == active_name else ""
    print(f"{Colors.BOLD}Profile: {name}{Colors.RESET}{Colors.GREEN}{is_active}{Colors.RESET}")
    print("─" * 40)

    for key, value in sorted(profile.items()):
        # Mask admin_key for security
        if key == 'admin_key' and value:
            display_value = value[:4] + '...' + value[-4:] if len(value) > 12 else '****'
        else:
            display_value = value
        print(f"  {key}: {display_value}")


def cmd_profile_delete(args, config: Dict[str, Any]):
    """Handle 'profile delete' command."""
    name = args.profile_name
    profiles = config.get('profiles', {})

    if name not in profiles:
        print(f"{Colors.RED}Error:{Colors.RESET} Profile '{name}' not found", file=sys.stderr)
        sys.exit(1)

    # Remove profile
    del config['profiles'][name]

    # Clear active profile if it was the deleted one
    if config.get('active_profile') == name:
        config['active_profile'] = None

    if save_config(config):
        print(f"{Colors.GREEN}Success:{Colors.RESET} Deleted profile '{name}'")


def cmd_export(args):
    """Handle 'export' command - export backends and routes."""
    base_url = args.url.rstrip('/')

    # Fetch backends
    backends_data = make_request_safe(
        f"{base_url}/admin/dump/backends",
        admin_key=args.admin_key,
        timeout=args.timeout
    )

    if backends_data is None:
        print(f"{Colors.RED}Error:{Colors.RESET} Failed to fetch backends", file=sys.stderr)
        sys.exit(1)

    # Fetch routes (tree)
    routes_data = make_request_safe(
        f"{base_url}/admin/dump/tree",
        admin_key=args.admin_key,
        timeout=args.timeout
    )

    if routes_data is None:
        print(f"{Colors.RED}Error:{Colors.RESET} Failed to fetch routes", file=sys.stderr)
        sys.exit(1)

    # Build export data
    export_data = {
        'version': 1,
        'exported_at': datetime.now().isoformat(),
        'source_url': args.url,
        'backends': backends_data.get('backends', []),
        'routes': routes_data
    }

    output_json = json.dumps(export_data, indent=2)

    # Write to file or stdout
    if args.export_file:
        try:
            with open(args.export_file, 'w') as f:
                f.write(output_json)
            if not args.quiet:
                backend_count = len(export_data['backends'])
                print(f"{Colors.GREEN}Success:{Colors.RESET} Exported {backend_count} backends to {args.export_file}")
        except IOError as e:
            print(f"{Colors.RED}Error:{Colors.RESET} Failed to write to {args.export_file}: {e}",
                  file=sys.stderr)
            sys.exit(1)
    else:
        print(output_json)


def cmd_import(args):
    """Handle 'import' command - import backends and routes."""
    base_url = args.url.rstrip('/')

    # Read import data
    if args.import_stdin:
        import_text = sys.stdin.read()
    elif args.import_file:
        try:
            with open(args.import_file, 'r') as f:
                import_text = f.read()
        except IOError as e:
            print(f"{Colors.RED}Error:{Colors.RESET} Failed to read {args.import_file}: {e}",
                  file=sys.stderr)
            sys.exit(1)
    else:
        print(f"{Colors.RED}Error:{Colors.RESET} Must specify --file or --stdin", file=sys.stderr)
        sys.exit(1)

    # Parse JSON
    try:
        import_data = json.loads(import_text)
    except json.JSONDecodeError as e:
        print(f"{Colors.RED}Error:{Colors.RESET} Invalid JSON: {e}", file=sys.stderr)
        sys.exit(1)

    # Validate format
    if 'backends' not in import_data:
        print(f"{Colors.RED}Error:{Colors.RESET} Invalid export format: missing 'backends' key",
              file=sys.stderr)
        sys.exit(1)

    backends = import_data.get('backends', [])

    if not args.quiet:
        print(f"{Colors.BOLD}Importing configuration...{Colors.RESET}")
        if import_data.get('source_url'):
            print(f"  Source: {import_data['source_url']}")
        if import_data.get('exported_at'):
            print(f"  Exported: {import_data['exported_at']}")
        print(f"  Backends: {len(backends)}")
        print()

    # Import backends
    imported_count = 0
    failed_count = 0

    for backend in backends:
        bid = backend.get('id')
        address = backend.get('address')
        port = backend.get('port')
        weight = backend.get('weight', 100)
        priority = backend.get('priority', 0)

        if bid is None or address is None or port is None:
            if not args.quiet:
                print(f"  {Colors.YELLOW}Skipping:{Colors.RESET} Invalid backend (missing id/address/port)")
            failed_count += 1
            continue

        # Build URL for backend add
        params = [
            f"id={bid}",
            f"ip={address}",
            f"port={port}",
            f"weight={weight}",
            f"priority={priority}"
        ]
        url = f"{base_url}/admin/backends?{'&'.join(params)}"

        # Dry-run mode
        if args.dry_run:
            imported_count += 1
            if not args.quiet:
                print(f"  {Colors.CYAN}[dry-run]{Colors.RESET} Would import backend {bid}: {address}:{port} (weight={weight}, priority={priority})")
            continue

        result = make_request_safe(url, method='POST', admin_key=args.admin_key,
                                    timeout=args.timeout)

        if result and result.get('status') == 'ok':
            imported_count += 1
            if not args.quiet:
                print(f"  {Colors.GREEN}✓{Colors.RESET} Backend {bid}: {address}:{port}")
        else:
            failed_count += 1
            if not args.quiet:
                error = result.get('error', 'unknown error') if result else 'connection failed'
                print(f"  {Colors.RED}✗{Colors.RESET} Backend {bid}: {error}")

    # Summary
    if not args.quiet:
        print()
        if args.dry_run:
            print(f"{Colors.CYAN}[dry-run]{Colors.RESET} Would import {imported_count} backends")
        elif failed_count == 0:
            print(f"{Colors.GREEN}Success:{Colors.RESET} Imported {imported_count} backends")
        else:
            print(f"{Colors.YELLOW}Completed:{Colors.RESET} {imported_count} imported, {failed_count} failed")

    if failed_count > 0:
        sys.exit(1)


