                        req_rate = (total - prev_total) / time_delta
                        success_rate_per_sec = (success - prev_success) / time_delta
                        fail_rate_per_sec = (failed - prev_failed) / time_delta

                # Update previous values for next iteration
                prev_total = total
                prev_success = success
                prev_failed = failed
                prev_time = current_time

                success_pct = (success / total * 100) if total > 0 else 0
                pct_color = Colors.GREEN if success_pct >= 99 else (Colors.YELLOW if success_pct >= 95 else Colors.RED)

