# Ranvier Core Configuration
# Copy this file to ranvier.yaml and customize as needed.
# All values shown are defaults - you only need to specify values you want to change.
# Environment variables override file settings (see comments for env var names).

# Server configuration
server:
  # IP address to bind to (RANVIER_BIND_ADDRESS)
  bind_address: "0.0.0.0"

  # Main API port for /v1/chat/completions and /admin/* endpoints (RANVIER_API_PORT)
  api_port: 8080

  # Prometheus metrics port (RANVIER_METRICS_PORT)
  metrics_port: 9180

# Database/persistence configuration
database:
  # SQLite database file path (RANVIER_DB_PATH)
  path: "ranvier.db"

  # SQLite journal mode: WAL, DELETE, TRUNCATE, PERSIST, MEMORY, OFF (RANVIER_DB_JOURNAL_MODE)
  journal_mode: "WAL"

  # SQLite synchronous mode: FULL, NORMAL, OFF (RANVIER_DB_SYNCHRONOUS)
  synchronous: "NORMAL"

# Health check configuration
health:
  # Interval between health checks in seconds (RANVIER_HEALTH_CHECK_INTERVAL)
  check_interval_seconds: 5

  # Timeout for each health check connection in seconds (RANVIER_HEALTH_CHECK_TIMEOUT)
  check_timeout_seconds: 3

  # Number of consecutive failures before marking backend as down
  failure_threshold: 3

  # Number of consecutive successes before marking backend as up
  recovery_threshold: 2

# Connection pool configuration
pool:
  # Maximum idle connections per backend host (RANVIER_POOL_MAX_PER_HOST)
  max_connections_per_host: 10

  # Close idle connections after this many seconds (RANVIER_POOL_IDLE_TIMEOUT)
  idle_timeout_seconds: 60

  # Maximum total idle connections across all backends (RANVIER_POOL_MAX_TOTAL)
  max_total_connections: 100

  # Enable TCP_NODELAY for lower latency (disables Nagle's algorithm)
  tcp_nodelay: true

# Routing and caching configuration
routing:
  # Minimum number of tokens before a route is learned/cached (RANVIER_MIN_TOKEN_LENGTH)
  # Set higher (e.g., 64) in production to avoid caching short prompts
  min_token_length: 4

  # Maximum attempts to find a live backend on cache miss
  backend_retry_limit: 5

  # Time in seconds to wait before fully removing a draining backend (RANVIER_BACKEND_DRAIN_TIMEOUT)
  # During this period, existing cache hits can still route to the backend (to leverage KV cache)
  # but new requests will not be assigned to the draining backend
  backend_drain_timeout_seconds: 60

# Timeout configuration
timeouts:
  # Timeout for establishing connection to backend in seconds (RANVIER_CONNECT_TIMEOUT)
  connect_timeout_seconds: 5

  # Total timeout for entire request in seconds (RANVIER_REQUEST_TIMEOUT)
  # Set high enough for LLM inference - 5 minutes default handles most generation tasks
  request_timeout_seconds: 300

# Asset paths
assets:
  # Path to GPT-2 tokenizer vocabulary JSON file (RANVIER_TOKENIZER_PATH)
  tokenizer_path: "assets/gpt2.json"

# TLS/HTTPS configuration
# Enable TLS for secure HTTPS connections to the API server
tls:
  # Enable TLS (RANVIER_TLS_ENABLED) - set to true to enable HTTPS
  enabled: false

  # Path to TLS certificate file in PEM format (RANVIER_TLS_CERT_PATH)
  # cert_path: "/path/to/cert.pem"

  # Path to TLS private key file in PEM format (RANVIER_TLS_KEY_PATH)
  # key_path: "/path/to/key.pem"

  # Example for self-signed certificate (development only):
  #   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes
  #
  # For production, use certificates from a trusted CA (e.g., Let's Encrypt)

# Authentication configuration
# Protect admin endpoints (/admin/*) with API key authentication
auth:
  # API key for admin endpoints (RANVIER_ADMIN_API_KEY)
  # When set, all /admin/* requests must include: Authorization: Bearer <api_key>
  # Leave empty to disable authentication (not recommended for production)
  # admin_api_key: "your-secret-api-key-here"

  # Example usage with curl:
  #   curl -X POST http://localhost:8080/admin/backends?id=1&ip=192.168.1.100&port=11434 \
  #     -H "Authorization: Bearer your-secret-api-key-here"

# Rate limiting configuration
# Prevent abuse by limiting requests per client IP
rate_limit:
  # Enable rate limiting (RANVIER_RATE_LIMIT_ENABLED)
  enabled: false

  # Maximum sustained requests per second per client (RANVIER_RATE_LIMIT_RPS)
  requests_per_second: 100

  # Allow short bursts above the rate limit (RANVIER_RATE_LIMIT_BURST)
  # Clients can make up to burst_size requests instantly before being limited
  burst_size: 50

# Retry configuration for transient backend failures
# Automatically retry connection attempts with exponential backoff
retry:
  # Maximum number of retry attempts (RANVIER_RETRY_MAX)
  # Set to 0 to disable retries
  max_retries: 3

  # Initial backoff delay in milliseconds (RANVIER_RETRY_INITIAL_BACKOFF_MS)
  initial_backoff_ms: 100

  # Maximum backoff delay in milliseconds (RANVIER_RETRY_MAX_BACKOFF_MS)
  max_backoff_ms: 5000

  # Exponential backoff multiplier (each retry waits multiplier * previous_delay)
  backoff_multiplier: 2.0

# Circuit breaker configuration for graceful degradation
# Automatically stops routing to failing backends and falls back to alternatives
circuit_breaker:
  # Enable circuit breaker (RANVIER_CIRCUIT_BREAKER_ENABLED)
  enabled: true

  # Number of consecutive failures before opening circuit (RANVIER_CIRCUIT_BREAKER_FAILURE_THRESHOLD)
  failure_threshold: 5

  # Number of consecutive successes in half-open state to close circuit (RANVIER_CIRCUIT_BREAKER_SUCCESS_THRESHOLD)
  success_threshold: 2

  # Time in seconds before attempting to recover (half-open state) (RANVIER_CIRCUIT_BREAKER_RECOVERY_TIMEOUT)
  recovery_timeout_seconds: 30

  # Enable fallback to alternative backends when primary fails (RANVIER_CIRCUIT_BREAKER_FALLBACK)
  fallback_enabled: true

# =============================================================================
# Backend Weights and Priorities (API Configuration)
# =============================================================================
# Backends support weight and priority parameters for heterogeneous clusters.
# These are configured per-backend via the admin API, not in this config file.
#
# Weight (default: 100):
#   Relative load balancing weight. Higher weight = more traffic.
#   A backend with weight=200 receives 2x traffic compared to weight=100.
#   Useful for directing more traffic to more powerful GPUs.
#
# Priority (default: 0):
#   Priority group for failover. Lower number = higher priority.
#   Ranvier routes to the highest priority group (lowest number) first.
#   If all backends in that group are down, it falls back to the next group.
#   Useful for primary/secondary/tertiary backend pools.
#
# Example API usage:
#   # Register a high-capacity backend (weight=200, priority=0 - primary)
#   curl -X POST "http://localhost:8080/admin/backends?id=1&ip=192.168.1.100&port=11434&weight=200&priority=0"
#
#   # Register a medium-capacity backend (weight=100, priority=0 - primary)
#   curl -X POST "http://localhost:8080/admin/backends?id=2&ip=192.168.1.101&port=11434&weight=100&priority=0"
#
#   # Register a fallback backend (weight=100, priority=1 - secondary)
#   curl -X POST "http://localhost:8080/admin/backends?id=3&ip=192.168.1.102&port=11434&weight=100&priority=1"
#
# Traffic distribution with above config (all backends healthy):
#   - Backend 1: 66% of traffic (200/300)
#   - Backend 2: 33% of traffic (100/300)
#   - Backend 3: 0% (only used if backends 1 and 2 are both down)
